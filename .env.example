# PostPilot Pro — Environment Variables
# ─────────────────────────────────────────────────

# META (Facebook + Instagram)
# Get from: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
REDIRECT_URI=http://localhost:5000/auth/facebook/callback

# GOOGLE BUSINESS
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# TIKTOK (Phase 4 — full auto-post)
# Get from: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# WEBSITE BANNER
# Your website just loads: <script src="https://YOUR-APP-URL/static/embed.js"></script>
WEBSITE_URL=https://yourwebsite.com

# APP CONFIG
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_ENV=development
DATABASE_URL=sqlite:///app.db
